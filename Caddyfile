# Reverse proxy con HTTPS automático (Let's Encrypt) para ufpcombat.com
ufpcombat.com {
	encode zstd gzip

	# HSTS va acá porque Caddy es quien termina el TLS. El resto de los headers
	# de seguridad los emite Next (ver `securityHeaders` en next.config.ts).
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		-Server
	}

	reverse_proxy web:3000
}

www.ufpcombat.com {
	redir https://ufpcombat.com{uri} permanent
}
