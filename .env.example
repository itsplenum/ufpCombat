# Entrega de los formularios (inscripción y patrocinios) por correo.
# Copia este archivo a `.env` en la VPS y rellena los valores.
# Sin estas variables, los formularios siguen funcionando y quedan en el log
# del contenedor (`docker compose logs web`) — solo no llega el correo.

# API key de Resend (https://resend.com → API Keys). Empieza por "re_".
RESEND_API_KEY=

# A dónde llegan las submissions. Con el remitente por defecto de Resend
# (onboarding@resend.dev) solo puede ser el correo dueño de la cuenta Resend.
SUBMISSIONS_EMAIL=

# Opcional. Remitente del correo. Déjalo vacío para usar onboarding@resend.dev.
# Cuando ufpcombat.com esté verificado en Resend: "UFP <noreply@ufpcombat.com>".
SUBMISSIONS_FROM=
